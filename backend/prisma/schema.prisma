// ─────────────────────────────────────────────────────────────
// BRAT EAT — Prisma Schema
// Source of truth for the database structure.
// Every entity matches DOMAIN_MODEL.md.
// Run: pnpm db:generate  after any schema change
// Run: pnpm db:migrate   to apply migrations (dev)
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────

/// Global role: controls platform-level access.
/// Organisation-level access is controlled by OrgRole on OrganizationMember.
enum GlobalRole {
  SUPER_ADMIN
  CUSTOMER

  @@map("global_role")
}

/// Role of a user within a specific organisation.
enum OrgRole {
  ORG_ADMIN
  MANAGER
  OPERATOR
  MARKETING

  @@map("org_role")
}

/// Lifecycle status of an organisation.
enum OrgStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED

  @@map("org_status")
}

/// Physical venue availability status.
enum VenueStatus {
  ACTIVE
  INACTIVE

  @@map("venue_status")
}

/// Lifecycle status of an event.
enum EventStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  CANCELLED

  @@map("event_status")
}

/// Operational status of a supplier during an event.
enum SupplierStatus {
  OPEN
  CLOSED
  PAUSED
  OFFLINE

  @@map("supplier_status")
}

/// Stripe Connect onboarding state for a supplier.
/// Drives whether the supplier can receive payments.
enum StripeAccountStatus {
  NOT_ONBOARDED   // No Stripe account created yet
  PENDING         // Account created, awaiting onboarding completion or Stripe review
  ACTIVE          // charges_enabled && payouts_enabled
  RESTRICTED      // Account exists but charges or payouts disabled (action required)

  @@map("stripe_account_status")
}

/// Lifecycle of a Cart.
/// A cart cannot accept items after CHECKOUT — items are frozen at that point.
enum CartStatus {
  OPEN              // Customer is editing
  CHECKOUT_PENDING  // PaymentIntent created, awaiting payment confirmation
  CONVERTED         // Payment succeeded, Order created
  EXPIRED           // expiresAt passed
  ABANDONED         // Cleared by customer or sweeper

  @@map("cart_status")
}

/// Lifecycle of an Order (post-payment).
/// Mirrors brain/ORDER_STATE_MACHINE.md.
enum OrderStatus {
  PAID
  ACCEPTED
  PREPARING
  READY
  PICKED_UP
  COMPLETED
  CANCELLED
  RECOVERED

  @@map("order_status")
}

/// Payment progression.
enum PaymentStatus {
  NOT_STARTED
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED

  @@map("payment_status")
}

/// Who triggered an order transition. Used in the audit trail.
enum OrderActorType {
  SYSTEM
  CUSTOMER
  OPERATOR
  ADMIN
  FLAIX

  @@map("order_actor_type")
}

/// Availability status of a pickup point.
enum PickupPointStatus {
  ACTIVE
  INACTIVE

  @@map("pickup_point_status")
}

// ─── PHASE 7 ENUMS ────────────────────────────────────────────

/// Availability status of a pickup slot.
enum SlotStatus {
  OPEN    // accepting orders (currentLoad < capacity)
  FULL    // capacity reached — no new orders
  CLOSED  // manually closed or expired

  @@map("slot_status")
}

/// Who created or last modified the slot.
enum SlotSource {
  MANUAL   // created by an operator via API
  DEFAULT  // generated from event default rules
  FLAIX    // assigned or modified by the Flaix AI engine

  @@map("slot_source")
}

/// Type of decision recorded from Flaix.
enum FlaixDecisionType {
  SLOT_DECISION
  RUSH_DECISION
  RECOMMENDATION_DECISION

  @@map("flaix_decision_type")
}

// ─── MODELS ───────────────────────────────────────────────────

/// A platform user: customer, operator, admin, or super admin.
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  displayName  String     @map("display_name")
  phone        String?
  globalRole   GlobalRole @default(CUSTOMER) @map("global_role")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  memberships      OrganizationMember[]
  refreshTokens    RefreshToken[]
  carts            Cart[]
  orders           Order[]
  groupMemberships GroupMember[]
  pushTokens       PushToken[]

  @@map("users")
}

/// Push programmé (C2) ou campagne promo automatique (C3).
/// kind = 'PUSH' (simple notification) | 'DISCOUNT_CAMPAIGN' (remise + push).
model ScheduledPush {
  id              String    @id @default(uuid())
  /// Null = broadcast plateforme (tous les utilisateurs). Rempli = ciblage par org.
  organizationId  String?   @map("organization_id")
  eventId         String?   @map("event_id")
  kind            String    @default("PUSH")
  title           String
  body            String    @default("")
  /// Pourcentage de remise pour les campagnes DISCOUNT_CAMPAIGN (ex. 50).
  discountPercent Int?      @map("discount_percent")
  scheduledAt     DateTime  @map("scheduled_at")
  status          String    @default("PENDING")
  sentAt          DateTime? @map("sent_at")
  sentCount       Int       @default(0) @map("sent_count")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([organizationId])
  @@map("scheduled_pushes")
}

/// Jeton de push Expo enregistré par un appareil client (notifications C1/C2/C3).
model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String   @default("unknown")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

/// A company, venue operator or event owner.
/// One organisation can own many venues, events and suppliers.
model Organization {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  status       OrgStatus @default(ACTIVE)
  settings     Json      @default("{}")
  /// PHASE 12.8 — Branding fields (URL-based, no file upload in V1)
  logoUrl      String?   @map("logo_url")
  primaryColor String?   @map("primary_color")
  description  String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  members      OrganizationMember[]
  venues       Venue[]
  events       Event[]
  suppliers    Supplier[]
  pickupPoints PickupPoint[]
  groups       Group[]
  /// PHASE 11 — reusable operator-dashboard screen definitions
  operatorScreenTemplates OperatorScreenTemplate[]
  scheduledPushes         ScheduledPush[]

  @@map("organizations")
}

/// Junction table: a user's role inside a specific organisation.
/// A user can be a member of multiple organisations with different roles.
/// For OPERATOR role, supplierId pins this member to a specific supplier.
model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  orgRole        OrgRole  @default(OPERATOR) @map("org_role")
  /// PHASE 12.7 — Operator assignment. Non-null only when orgRole = OPERATOR.
  supplierId     String?  @map("supplier_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier?    @relation("OperatorAssignments", fields: [supplierId], references: [id], onDelete: SetNull)

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// ─── PHASE 3 MODELS ───────────────────────────────────────────

/// A physical location owned by an organisation.
/// One venue can host many events and pickup points.
model Venue {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  name           String
  address        String
  /// PHASE 16 — coordonnées pour la découverte géolocalisée (app mobile). Nullable.
  latitude       Float?
  longitude      Float?
  /// PHASE 16.2 — mots-clés libres saisis par le club pour la recherche (ex.
  /// "marseille, spartiates, patinoire"). Matché en plus du nom/adresse.
  searchTerms    String?     @map("search_terms")
  /// PHASE 16.3 — intégration Flaix (API). Quand flaixEnabled, l'app passe le relais
  /// à Flaix au lieu du parcours Break Eat natif ; flaixVenueId = identifiant du lieu
  /// côté Flaix (utilisé par les appels API Flaix, à brancher au contrat Flaix).
  flaixEnabled   Boolean     @default(false) @map("flaix_enabled")
  flaixVenueId   String?     @map("flaix_venue_id")
  timezone       String      @default("Europe/Paris")
  status         VenueStatus @default(ACTIVE)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       Event[]
  pickupPoints PickupPoint[]

  @@map("venues")
}

/// A time-bound ordering context. Belongs to one org and one venue.
/// An event activates suppliers, pickup points, and slots.
model Event {
  id                 String      @id @default(uuid())
  organizationId     String      @map("organization_id")
  venueId            String      @map("venue_id")
  name               String
  startAt            DateTime    @map("start_at")
  endAt              DateTime    @map("end_at")
  status             EventStatus @default(DRAFT)
  activeFeatureFlags Json        @default("{}") @map("active_feature_flags")
  /// PHASE 14 — public (everyone) or private (restricted to linked groups).
  visibility         EventVisibility @default(PUBLIC)
  /// PHASE 12.8 — Branding & content shown in mobile app
  description        String?
  logoUrl            String?     @map("logo_url")
  primaryColor       String?     @map("primary_color")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  venue          Venue           @relation(fields: [venueId], references: [id])
  eventSuppliers EventSupplier[]
  pickupPoints   PickupPoint[]
  carts          Cart[]
  slots          Slot[]
  flaixDecisions FlaixDecision[]
  groups         EventGroup[]
  /// PHASE 11 — screen templates applied to this event (with per-event order/toggle)
  operatorScreens EventOperatorScreen[]
  scheduledPushes ScheduledPush[]

  @@map("events")
}

/// A food, drink or merchandise operator attached to an event.
/// Belongs to an organisation; connected to events via EventSupplier junction.
model Supplier {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  name            String
  status          SupplierStatus @default(CLOSED)
  preparationZone String?        @map("preparation_zone")
  /// Exploitant externe (food-truck, traiteur tiers…) référencé via code de parrainage.
  isExternal      Boolean        @default(false) @map("is_external")
  /// Code de parrainage unique — partagé à l'exploitant externe pour le rattacher au club.
  referralCode    String?        @unique @map("referral_code")
  /// Stripe Connect account ID — populated during Phase 5 onboarding.
  stripeAccountId       String?              @map("stripe_account_id")
  stripeAccountStatus   StripeAccountStatus  @default(NOT_ONBOARDED) @map("stripe_account_status")
  /// Mirror of Stripe Account.charges_enabled — refreshed on each status check.
  stripeChargesEnabled  Boolean              @default(false) @map("stripe_charges_enabled")
  /// Mirror of Stripe Account.payouts_enabled — refreshed on each status check.
  stripePayoutsEnabled  Boolean              @default(false) @map("stripe_payouts_enabled")
  /// Timestamp when the account first reached ACTIVE state.
  stripeOnboardedAt     DateTime?            @map("stripe_onboarded_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventSuppliers    EventSupplier[]
  pickupPoints      PickupPoint[]
  categories        Category[]
  products          Product[]
  stocks            Stock[]
  carts             Cart[]
  slots             Slot[]
  /// PHASE 12.7 — operators assigned to this supplier
  assignedOperators OrganizationMember[] @relation("OperatorAssignments")

  @@map("suppliers")
}

/// Junction: a supplier assigned to a specific event.
/// @@unique prevents the same supplier from being attached twice.
model EventSupplier {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  supplierId String   @map("supplier_id")
  createdAt  DateTime @default(now()) @map("created_at")

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([eventId, supplierId])
  @@map("event_suppliers")
}

/// A named pickup location inside a venue.
/// Optionally scoped to an event and/or a specific supplier.
model PickupPoint {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  venueId        String            @map("venue_id")
  eventId        String?           @map("event_id")
  supplierId     String?           @map("supplier_id")
  name           String
  status         PickupPointStatus @default(ACTIVE)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  venue        Venue        @relation(fields: [venueId], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])
  supplier     Supplier?    @relation(fields: [supplierId], references: [id])
  stocks       Stock[]
  carts        Cart[]
  slots        Slot[]

  @@map("pickup_points")
}

// ─── END PHASE 3 ──────────────────────────────────────────────

// ─── PHASE 4 ENUMS ────────────────────────────────────────────

/// Visibility status of a product category.
enum CategoryStatus {
  ACTIVE
  INACTIVE
  ARCHIVED

  @@map("category_status")
}

/// Product lifecycle status.
/// OUT_OF_STOCK = temporarily unavailable but not archived.
enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  ARCHIVED

  @@map("product_status")
}

// ─── PHASE 4 MODELS ───────────────────────────────────────────

/// A menu category belonging to one supplier.
/// Products are grouped by category for display and ordering.
/// Deleting a category is blocked if it has products (Restrict FK).
model Category {
  id         String         @id @default(uuid())
  supplierId String         @map("supplier_id")
  name       String
  sortOrder  Int            @default(0) @map("sort_order")
  status     CategoryStatus @default(ACTIVE)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  supplier Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("categories")
}

/// A product offered by a supplier within a category.
/// price is stored in CENTS (Int) — never Float for money.
/// availableFrom/availableUntil support time-window menus (e.g. breakfast until 11h).
model Product {
  id             String        @id @default(uuid())
  supplierId     String        @map("supplier_id")
  categoryId     String        @map("category_id")
  name           String
  description    String?
  /// Price in cents. 250 = €2.50. Must be >= 0.
  price          Int
  imageUrl       String?       @map("image_url")
  status         ProductStatus @default(ACTIVE)
  availableFrom  DateTime?     @map("available_from")
  availableUntil DateTime?     @map("available_until")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  supplier  Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category  Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  stocks    Stock[]
  cartItems CartItem[]

  @@map("products")
}

/// Stock entry: available quantity of a product.
/// Scoped to a supplier, optionally to a specific pickup point.
/// When quantity = 0, the service automatically sets isAvailable = false.
/// OPERATOR can manually toggle isAvailable (e.g. 86 an item mid-service).
/// Uniqueness: one global entry per product (pickupPointId = null) enforced at service level.
///             one entry per (product, pickupPoint) enforced by DB partial index.
model Stock {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  supplierId    String   @map("supplier_id")
  pickupPointId String?  @map("pickup_point_id")
  quantity      Int      @default(0)
  isAvailable   Boolean  @default(true) @map("is_available")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier    Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  pickupPoint PickupPoint? @relation(fields: [pickupPointId], references: [id], onDelete: SetNull)

  @@map("stock")
}

// ─── END PHASE 4 ──────────────────────────────────────────────

// ─── PHASE 5 MODELS ───────────────────────────────────────────

/// A shopping cart belonging to a user.
/// V1 = single-vendor: one cart targets exactly one supplier.
/// Items, totals and pickup point are persisted on the cart;
/// snapshots are taken later, on Order creation.
model Cart {
  id             String     @id @default(uuid())
  userId         String     @map("user_id")
  eventId        String     @map("event_id")
  supplierId     String     @map("supplier_id")
  pickupPointId  String?    @map("pickup_point_id")
  /// Phase 7 — customer-selected slot before checkout.
  selectedSlotId String?    @map("selected_slot_id")
  status         CartStatus @default(OPEN)
  /// Idempotency safeguard for /checkout — same key returns the same PaymentIntent.
  paymentIntentId String?   @map("payment_intent_id")
  expiresAt      DateTime   @map("expires_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  supplier    Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  pickupPoint PickupPoint? @relation(fields: [pickupPointId], references: [id], onDelete: SetNull)
  slot        Slot?        @relation(fields: [selectedSlotId], references: [id], onDelete: SetNull)
  items       CartItem[]

  @@index([userId, status])
  @@index([eventId])
  @@map("carts")
}

/// A line item in a cart. Live product price is used while the cart is OPEN.
/// At checkout, the live price is frozen into `priceSnapshotCents` so that the
/// PaymentIntent amount and the future Order.totalCents stay consistent even
/// if Product.price changes between checkout and webhook delivery.
model CartItem {
  id                 String   @id @default(uuid())
  cartId             String   @map("cart_id")
  productId          String   @map("product_id")
  quantity           Int
  /// Frozen unit price (cents) captured at checkout. NULL while cart is OPEN.
  priceSnapshotCents Int?     @map("price_snapshot_cents")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

/// A confirmed customer order — created ONLY after payment_intent.succeeded.
/// Stores price + product snapshots so historical orders never depend on
/// mutable Product / Stock rows.
///
/// V1: one Order = one Supplier (multi-vendor flag stays OFF in V1).
model Order {
  id                String        @id @default(uuid())
  /// Human-readable, unique identifier shown to customer + operator (e.g. BE-00000123).
  publicOrderNumber String        @unique @map("public_order_number")
  userId            String        @map("user_id")
  organizationId    String        @map("organization_id")
  eventId           String        @map("event_id")
  venueId           String        @map("venue_id")
  supplierId        String        @map("supplier_id")
  pickupPointId     String        @map("pickup_point_id")
  /// Phase 7 — slot assignment.
  slotId            String?       @map("slot_id")
  status            OrderStatus   @default(PAID)
  paymentStatus     PaymentStatus @default(SUCCEEDED) @map("payment_status")
  /// Frozen totals at order creation. Never recomputed.
  subtotalCents     Int           @map("subtotal_cents")
  totalCents        Int           @map("total_cents")
  currency          String        @default("eur")
  /// Phase 9 — analytics tags.
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user        User             @relation(fields: [userId], references: [id])
  slot        Slot?            @relation(fields: [slotId], references: [id], onDelete: SetNull)
  items       OrderItem[]
  payments    Payment[]
  auditTrail  OrderAuditTrail[]

  @@index([userId])
  @@index([eventId, status])
  @@index([supplierId, status])
  @@index([slotId])
  @@index([organizationId])
  @@map("orders")
}

/// Frozen snapshot of one line at order creation.
/// productId is kept for traceability; productNameSnapshot is the displayed name.
model OrderItem {
  id                    String   @id @default(uuid())
  orderId               String   @map("order_id")
  productId             String   @map("product_id")
  productNameSnapshot   String   @map("product_name_snapshot")
  unitPriceCentsSnapshot Int     @map("unit_price_cents_snapshot")
  quantity              Int
  lineTotalCents        Int      @map("line_total_cents")
  createdAt             DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

/// A Stripe PaymentIntent attached to an Order.
/// Multiple Payments per Order are possible (e.g. partial refunds in Phase 9).
model Payment {
  id                    String        @id @default(uuid())
  orderId               String?       @map("order_id")
  stripePaymentIntentId String        @unique @map("stripe_payment_intent_id")
  status                PaymentStatus @default(NOT_STARTED)
  amountCents           Int           @map("amount_cents")
  currency              String        @default("eur")
  failureReason         String?       @map("failure_reason")
  /// Raw last-known Stripe object — useful for debugging without re-querying Stripe.
  rawStripeEvent        Json?         @map("raw_stripe_event")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("payments")
}

/// Append-only audit log for every Order transition.
/// Never updated — only inserted.
model OrderAuditTrail {
  id            String         @id @default(uuid())
  orderId       String         @map("order_id")
  actorType     OrderActorType @map("actor_type")
  actorId       String?        @map("actor_id")
  previousState String?        @map("previous_state")
  nextState     String         @map("next_state")
  reason        String?
  metadata      Json           @default("{}")
  createdAt     DateTime       @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_audit_trail")
}

/// Stripe webhook event log — store every received event for idempotency.
/// One row per Stripe event id. Duplicates are rejected on insert.
model WebhookEvent {
  id              String   @id @default(uuid())
  stripeEventId   String   @unique @map("stripe_event_id")
  eventType       String   @map("event_type")
  processedAt     DateTime? @map("processed_at")
  receivedAt      DateTime @default(now()) @map("received_at")
  rawPayload      Json     @map("raw_payload")

  @@index([eventType, receivedAt])
  @@map("webhook_events")
}

// ─── END PHASE 5 ──────────────────────────────────────────────

// ─── PHASE 7 MODELS ───────────────────────────────────────────

/// A time-bounded pickup slot for an event.
/// Capacity management: currentLoad is incremented atomically on order assignment.
/// Status transitions: OPEN → FULL (auto when currentLoad = capacity) | CLOSED (manual).
/// source tracks whether a human or Flaix created/modified the slot.
model Slot {
  id            String     @id @default(uuid())
  eventId       String     @map("event_id")
  /// null = slot applies to all suppliers in the event
  supplierId    String?    @map("supplier_id")
  /// null = slot applies to all pickup points in the event
  pickupPointId String?    @map("pickup_point_id")
  startAt       DateTime   @map("start_at")
  endAt         DateTime   @map("end_at")
  capacity      Int
  currentLoad   Int        @default(0) @map("current_load")
  status        SlotStatus @default(OPEN)
  source        SlotSource @default(MANUAL)
  /// PHASE 11 — Stable "moment de récupération" role. Portable across events so
  /// reusable operator-screen templates can target a moment (IMMEDIATE / PAUSE_1…)
  /// without hard-coding per-event slot UUIDs. An order with slotId = null is
  /// treated as IMMEDIATE by the screen-matching logic.
  kind          SlotKind   @default(IMMEDIATE)
  /// Human-readable label shown to customers (e.g. "12:00–12:15")
  label         String?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  pickupPoint    PickupPoint?    @relation(fields: [pickupPointId], references: [id], onDelete: SetNull)
  orders         Order[]
  carts          Cart[]
  flaixDecisions FlaixDecision[]

  @@index([eventId, status])
  @@index([eventId, startAt])
  @@map("slots")
}

/// Append-only log of every Flaix decision that was received and applied.
/// Stored regardless of whether the backend accepted or overrode the decision.
/// decisionId is the Flaix-generated UUID — used as idempotency key (UNIQUE).
model FlaixDecision {
  id            String            @id @default(uuid())
  /// Flaix-generated UUID. Unique — prevents double-application of the same decision.
  decisionId    String            @unique @map("decision_id")
  type          FlaixDecisionType
  eventId       String            @map("event_id")
  /// Slot affected by this decision (if applicable)
  slotId        String?           @map("slot_id")
  /// Raw Flaix response payload — never mutated after storage
  sourcePayload Json              @map("source_payload")
  /// What the backend did with the decision (e.g. "slot_assigned", "ignored", "fallback_applied")
  appliedAction String            @map("applied_action")
  /// UUIDs of orders, slots, products affected
  affectedIds   String[]          @map("affected_ids")
  createdAt     DateTime          @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  slot  Slot? @relation(fields: [slotId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([type, eventId])
  @@map("flaix_decisions")
}

// ─── END PHASE 7 ──────────────────────────────────────────────

// ─── PHASE 9 ENUMS ────────────────────────────────────────────

/// Scope of a feature flag or app setting.
/// Resolution precedence: EVENT > ORGANIZATION > GLOBAL.
enum FlagScope {
  GLOBAL
  ORGANIZATION
  EVENT

  @@map("flag_scope")
}

// ─── PHASE 9 MODELS ───────────────────────────────────────────

/// Feature flags — control feature availability per scope without redeploy.
/// A flag not found at EVENT scope falls back to ORGANIZATION, then GLOBAL.
/// scopeId is the organization or event UUID when scope ≠ GLOBAL.
model FeatureFlag {
  id        String    @id @default(uuid())
  key       String
  scope     FlagScope
  scopeId   String?   @map("scope_id")
  enabled   Boolean   @default(false)
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([key, scope, scopeId])
  @@index([key, scope])
  @@map("feature_flags")
}

/// App settings / basic CMS — JSON key-value store per scope.
/// Typical keys: email_header_text, banner_message, event_description,
///               max_orders_per_slot, payment_provider_label.
model AppSetting {
  id        String    @id @default(uuid())
  key       String
  scope     FlagScope
  scopeId   String?   @map("scope_id")
  value     Json
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([key, scope, scopeId])
  @@index([key, scope])
  @@map("app_settings")
}

// ─── END PHASE 9 ──────────────────────────────────────────────

// ─── PHASE 14 ENUMS ───────────────────────────────────────────

/// How a user became a member of a group.
/// MANUAL = added by hand (by email) ; DOMAIN = auto-joined via emailDomain rule.
enum GroupMemberSource {
  MANUAL
  DOMAIN

  @@map("group_member_source")
}

/// Whether an event is open to everyone or restricted to linked groups.
/// Resolution is enforced server-side — never trusted from the client.
enum EventVisibility {
  PUBLIC
  PRIVATE

  @@map("event_visibility")
}

// ─── PHASE 14 MODELS ──────────────────────────────────────────

/// A segment of users inside ONE organisation.
/// V1 use: gate access to PRIVATE events. Later: targeted promo codes.
/// emailDomain (optional) auto-enrols users whose email matches on signup.
model Group {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  /// Auto-join rule, e.g. "boursorama.com". Stored lowercased, without "@".
  emailDomain    String?  @map("email_domain")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      GroupMember[]
  events       EventGroup[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([emailDomain])
  @@map("groups")
}

/// Junction: a user's membership in a group.
/// source records whether it was a manual add or a domain auto-join.
model GroupMember {
  id        String            @id @default(uuid())
  groupId   String            @map("group_id")
  userId    String            @map("user_id")
  source    GroupMemberSource @default(MANUAL)
  createdAt DateTime          @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

/// Junction: which groups may access a PRIVATE event.
/// An event with no rows here and visibility=PRIVATE is accessible to nobody.
model EventGroup {
  eventId   String   @map("event_id")
  groupId   String   @map("group_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([eventId, groupId])
  @@index([groupId])
  @@map("event_groups")
}

// ─── END PHASE 14 ─────────────────────────────────────────────

// ─── PHASE 11 ENUMS ───────────────────────────────────────────
// (Added after Phase 14 chronologically — Phase 11 = the operator dashboard.)

/// Stable "moment de récupération" role for a slot. Lets reusable operator-screen
/// templates target a pickup moment across events without per-event slot UUIDs.
/// IMMEDIATE  = prepare/collect as soon as possible ("Commandes Immédiates")
/// PAUSE_1    = first break / half-time ("1ère mi-temps")
/// PAUSE_2    = second break / half-time ("2ème mi-temps")
/// GENERAL    = no specific moment (catch-all)
/// CUSTOM     = operator-defined moment not covered above
enum SlotKind {
  IMMEDIATE
  PAUSE_1
  PAUSE_2
  GENERAL
  CUSTOM

  @@map("slot_kind")
}

/// What a configurable operator screen displays. Drives the default status set
/// when a template leaves `statuses` empty.
/// ORDERS_QUEUE = live preparation pipeline (PAID → ACCEPTED → PREPARING)
/// READY        = orders marked READY, awaiting hand-over
/// RECOVERED    = handed over (PICKED_UP / RECOVERED)
/// GENERAL      = every active order regardless of moment
enum OperatorScreenKind {
  ORDERS_QUEUE
  READY
  RECOVERED
  GENERAL

  @@map("operator_screen_kind")
}

// ─── PHASE 11 MODELS ──────────────────────────────────────────

/// A reusable operator-dashboard screen definition, owned by ONE organisation.
/// Defined once (e.g. "Commandes Immédiates — Spartiates buvette") and applied to
/// many events via EventOperatorScreen — so the same board configuration is reused
/// every match without rebuilding it.
///
/// Display conditions decide which orders appear on the screen:
///   slotKinds   — which pickup moments (empty = all moments; null-slot ⇒ IMMEDIATE)
///   statuses    — which order statuses (empty = sensible default derived from `kind`)
///   supplierIds — which suppliers (empty = all suppliers active on the event)
///   filters     — finer JSON rules: category include/exclude, product on/off,
///                 récap panel toggle, batching preferences. Shape (all optional):
///                 { categoryIds?: string[], excludeCategoryIds?: string[],
///                   productIds?: string[], excludeProductIds?: string[],
///                   showRecap?: boolean }
model OperatorScreenTemplate {
  id             String             @id @default(uuid())
  organizationId String             @map("organization_id")
  name           String
  kind           OperatorScreenKind @default(ORDERS_QUEUE)
  /// Optional emoji / icon shown on the screen tab (e.g. "🏪", "⚡").
  icon           String?
  /// Default tab order; can be overridden per-event on EventOperatorScreen.
  sortOrder      Int                @default(0) @map("sort_order")
  /// Soft on/off at the template level (independent of per-event toggle).
  enabled        Boolean            @default(true)
  /// Pickup moments shown (empty = all). Stable across events.
  slotKinds      SlotKind[]         @map("slot_kinds")
  /// Order statuses shown (empty = default derived from `kind`).
  statuses       OrderStatus[]
  /// Suppliers shown (empty = all suppliers active on the event).
  supplierIds    String[]           @map("supplier_ids")
  /// Finer display rules — see model doc for shape.
  filters        Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventScreens EventOperatorScreen[]

  @@index([organizationId])
  @@map("operator_screen_templates")
}

/// Junction: applies a screen template to a specific event. Lets a manager pick
/// which templates run on an event and reorder / disable them there, without
/// editing the shared template (which other events may also use).
model EventOperatorScreen {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  templateId String   @map("template_id")
  /// Per-event tab-order override; null ⇒ fall back to template.sortOrder.
  sortOrder  Int?     @map("sort_order")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  event    Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template OperatorScreenTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([eventId, templateId])
  @@index([eventId])
  @@map("event_operator_screens")
}

// ─── END PHASE 11 ─────────────────────────────────────────────

/// Hashed refresh tokens for secure JWT rotation.
/// One row per active session. Deleted on logout or rotation.
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
