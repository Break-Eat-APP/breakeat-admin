# Workspace configuration
# ─────────────────────────────────────────────────────────
# Do NOT enforce strict corepack version matching at runtime.
# Turbo v2 resolves the pnpm binary via PATH; strict mode can
# cause "Unable to find package manager binary" on machines where
# pnpm is installed globally (npm i -g) rather than via corepack shims.
package-manager-strict=false

# Ensure .npmrc is respected in all workspace packages
shared-workspace-lockfile=true
