# ─────────────────────────────────────────────
# BRAT EAT — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=3000
# APP_ENV is used by Sentry configs for environment tagging (production | staging | development)
APP_ENV=development
# LOG_LEVEL controls minimum log level emitted (verbose | debug | log | warn | error | fatal)
# Default: log in production, debug elsewhere
LOG_LEVEL=debug

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://brateat:brateat@localhost:5432/brateat_dev

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-before-production
JWT_EXPIRES_IN=7d

# ── Stripe Connect ───────────────────────────
# Platform secret key (BRAT EAT account)
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
# Webhook signing secret (from Stripe dashboard)
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
# Stripe API version — pinned for reproducible behaviour
STRIPE_API_VERSION=2024-12-18.acacia
# Platform commission in basis points (100 = 1%, 500 = 5%)
STRIPE_PLATFORM_FEE_BPS=500
# Where Stripe redirects after Connect onboarding (public URL)
STRIPE_CONNECT_RETURN_URL=http://localhost:3001/suppliers/onboarding/complete
STRIPE_CONNECT_REFRESH_URL=http://localhost:3001/suppliers/onboarding/refresh

# ── Sentry ───────────────────────────────────
SENTRY_DSN_BACKEND=https://PLACEHOLDER@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN_MOBILE=https://PLACEHOLDER@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN_ADMIN=https://PLACEHOLDER@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN_OPERATOR=https://PLACEHOLDER@oXXXXXX.ingest.sentry.io/XXXXXXX
# Operator app — public DSN (exposed to browser bundle)
NEXT_PUBLIC_SENTRY_DSN_OPERATOR=https://PLACEHOLDER@oXXXXXX.ingest.sentry.io/XXXXXXX
# Sentry CLI — source map upload (CI / Vercel only, never local)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=break-eat
SENTRY_PROJECT=operator

# ── Storage (S3-compatible) ──────────────────
STORAGE_ENDPOINT=https://PLACEHOLDER
STORAGE_ACCESS_KEY=PLACEHOLDER
STORAGE_SECRET_KEY=PLACEHOLDER
STORAGE_BUCKET=brateat-media
STORAGE_REGION=eu-west-1

# ── Flaix (Phase 7 — leave empty until integration) ──
FLAIX_API_URL=
FLAIX_API_KEY=

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ── Admin App (Phase 11) ─────────────────────
# Backend API base URL consumed by the admin Next.js app.
# Override in production with the deployed backend URL.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ── Demo Mode (Phase 6+) ──────────────────────
# When 'true', /admin/simulator and /demo endpoints are exposed.
# NEVER enable in production. Only staging or local dev.
DEMO_MODE=false
# Required token to call staging-only endpoints (simulators, seeders).
STAGING_ONLY_TOKEN=change-me-on-staging
